# Template for secrets.properties.
# Copy this file to "secrets.properties" (which is git-ignored) and fill in real values:
#
#   cp secrets.properties.template secrets.properties
#
# Get the Client ID from https://developer.spotify.com/dashboard
# The redirect URI must be registered in your Spotify app settings AND match below.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_REDIRECT_URI=your://redirect/here