<?xml version="1.0" encoding="utf-8"?>
<!--
    Author: Claude (Anthropic)
    Last modified: 2026-06-23
    Version log:
      2026-06-23 - Created album-section header row (text only: album title + album artist). A cover-art
                   thumbnail on the left is planned but intentionally omitted for now.
      2026-06-23 - Use theme-aware @color resources so the header adapts to light/dark mode.
      2026-06-23 - Taller header with a square color block on the left 1/3 (placeholder cover art) and
                   the title/artist in the right 2/3. Row height and square size are set in code.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/album_header_bg">

    <!-- Placeholder "album cover" square. Width/height are overridden in code to 1/3 screen width. -->
    <View
        android:id="@+id/albumHeaderCover"
        android:layout_width="120dp"
        android:layout_height="120dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/albumHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/album_header_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/albumHeaderArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/album_header_artist"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
